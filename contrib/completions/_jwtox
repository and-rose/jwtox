#compdef jwtox

autoload -U is-at-least

_jwtox() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-f+[Extract a single, top-level claim from the payload]:FIELD:_default' \
'--field=[Extract a single, top-level claim from the payload]:FIELD:_default' \
'-k+[The key to use for signature verification]:KEY_FILE:_default' \
'--key-file=[The key to use for signature verification]:KEY_FILE:_default' \
'-c[Do not calculate the dates for iat, exp, and nbf]' \
'--no-calc[Do not calculate the dates for iat, exp, and nbf]' \
'-n[No color output]' \
'--no-color[No color output]' \
'(-P --payload-only -S --signature-only)-H[Only print the header as JSON]' \
'(-P --payload-only -S --signature-only)--header-only[Only print the header as JSON]' \
'(-H --header-only -S --signature-only)-P[Only print the payload as JSON]' \
'(-H --header-only -S --signature-only)--payload-only[Only print the payload as JSON]' \
'-p[pretty print the output instead of compact JSON (only applies when printing header and/or payload)]' \
'--pretty[pretty print the output instead of compact JSON (only applies when printing header and/or payload)]' \
'(-H --header-only -P --payload-only)-S[Only print the signature as a base64 string]' \
'(-H --header-only -P --payload-only)--signature-only[Only print the signature as a base64 string]' \
'-u[Print dates in UTC instead of local time]' \
'--utc[Print dates in UTC instead of local time]' \
'(-k --key-file)-v[Verify the signature by reaching out to the authority specified in the "iss" claim using the JWKs endpoint]' \
'(-k --key-file)--verify-jwks[Verify the signature by reaching out to the authority specified in the "iss" claim using the JWKs endpoint]' \
'(-X --clear-cache)-C[]' \
'(-X --clear-cache)--no-cache[]' \
'(-C --no-cache)-X[]' \
'(-C --no-cache)--clear-cache[]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::JWT -- The JWT token to decode. If not provided, it will be read from stdin:_default' \
&& ret=0
}

(( $+functions[_jwtox_commands] )) ||
_jwtox_commands() {
    local commands; commands=()
    _describe -t commands 'jwtox commands' commands "$@"
}

if [ "$funcstack[1]" = "_jwtox" ]; then
    _jwtox "$@"
else
    compdef _jwtox jwtox
fi
